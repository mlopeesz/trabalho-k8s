pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: node
    image: node:18
    command:
    - cat
    tty: true
"""
        }
    }

    stages {
        stage('Run App') {
            steps {
                container('node') {
                    sh 'npm install'
                    sh 'npm test || true'
                }
            }
        }
    }
}